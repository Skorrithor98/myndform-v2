---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Forsíða">

  <!-- HERO -->
  <section class="hero">
    <div class="hero-inner">
      <div class="hero-label">Kvikmyndadreifing & þjónusta</div>
      <h1>Við komum<br/><em>myndunum</em><br/>í bíó.</h1>
      <p>Myndform hefur þjónað íslenskum kvikmyndahúsum, smásöluaðilum og auglýsendum í áratugi.</p>
    </div>
    <div class="hero-line"></div>
  </section>

  <!-- UPCOMING FILMS -->
  <section class="upcoming fade-in">
    <div class="upcoming-inner">
      <div class="upcoming-left">
        <div class="section-label">Væntanlegt í bíó</div>
      </div>
      <div class="upcoming-films">
        <a href="/films" class="upcoming-film">
          <span class="upcoming-date">1. júlí</span>
          <span class="upcoming-title">Skósveinar og skrímsli</span>
          <span class="upcoming-arrow">→</span>
        </a>
        <a href="/films" class="upcoming-film">
          <span class="upcoming-date">16. júlí</span>
          <span class="upcoming-title">The Odyssey</span>
          <span class="upcoming-arrow">→</span>
        </a>
        <a href="/films" class="upcoming-film">
          <span class="upcoming-date">13. ágúst</span>
          <span class="upcoming-title">Cliffhanger</span>
          <span class="upcoming-arrow">→</span>
        </a>
        <a href="/films" class="upcoming-film">
          <span class="upcoming-date">19. nóvember</span>
          <span class="upcoming-title">Hunger Games: Sunrise on the Reaping</span>
          <span class="upcoming-arrow">→</span>
        </a>
      </div>
      <a href="/films" class="see-all">Sjá allar myndir →</a>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services fade-in">
    <div class="services-header">
      <div class="section-label">Þjónusta</div>
      <h2>Við gerum meira<br/>en dreifa myndum.</h2>
    </div>
    <div class="services-grid">
      <a href="/portfolio" class="service-card">
        <div class="service-number">01</div>
        <div class="service-name">Auglýsingahönnun</div>
        <div class="service-desc">Hönnun og framleiðsla auglýsinga þvert á miðla — frá hugmynd til framkvæmdar.</div>
        <div class="service-link">Sjá nánar →</div>
      </a>
      <a href="/prentun" class="service-card">
        <div class="service-number">02</div>
        <div class="service-name">Prentun</div>
        <div class="service-desc">Bílamerkingar, innréttingafilmur, skiltagerð og stór prentverkefni.</div>
        <div class="service-link">Sjá nánar →</div>
      </a>
      <a href="/hljodver" class="service-card">
        <div class="service-number">03</div>
        <div class="service-name">Hljóðver</div>
        <div class="service-desc">Fagleg hljóðver til leigu fyrir þætti, auglýsingar og kvikmyndir.</div>
        <div class="service-link">Sjá nánar →</div>
      </a>
      <a href="/heildsala" class="service-card">
        <div class="service-number">04</div>
        <div class="service-name">Heildsala</div>
        <div class="service-desc">Dreifing á borðspilum, leikföngum og mat- og drykkjarvörum.</div>
        <div class="service-link">Sjá nánar →</div>
      </a>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section fade-in">
    <div class="cta-inner">
      <h2>Langar þig að vinna með okkur?</h2>
      <a href="mailto:myndform@myndform.is" class="cta-btn">Hafðu samband</a>
    </div>
  </section>

</Layout>

<style>
  /* ── HERO ── */
  .hero {
    padding: 120px 48px 80px;
    border-bottom: 1px solid var(--gray-20);
  }
  .hero-inner { max-width: 800px; }
  .section-label {
    font-size: 11px; font-weight: 500; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--gray-60); margin-bottom: 24px;
    display: flex; align-items: center; gap: 10px;
  }
  .section-label::before {
    content: ''; width: 24px; height: 1px; background: var(--red);
  }
  h1 {
    font-family: var(--display);
    font-size: clamp(56px, 8vw, 96px);
    font-weight: 300; line-height: 1.05;
    letter-spacing: -0.02em; color: var(--black);
    margin-bottom: 28px;
  }
  h1 em {
    font-style: italic; color: var(--red);
  }
  .hero-inner p {
    font-size: 18px; color: var(--gray-60);
    line-height: 1.7; max-width: 480px;
  }

  /* ── UPCOMING ── */
  .upcoming {
    padding: 64px 48px;
    border-bottom: 1px solid var(--gray-20);
  }
  .upcoming-inner {
    display: grid; grid-template-columns: 200px 1fr auto;
    gap: 48px; align-items: start;
  }
  .upcoming-films { display: flex; flex-direction: column; }
  .upcoming-film {
    display: grid; grid-template-columns: 100px 1fr 24px;
    align-items: center; gap: 24px;
    padding: 16px 0; border-bottom: 1px solid var(--gray-20);
    text-decoration: none; color: inherit;
    transition: padding-left 0.2s;
  }
  .upcoming-film:first-child { border-top: 1px solid var(--gray-20); }
  .upcoming-film:hover { padding-left: 8px; }
  .upcoming-date {
    font-size: 12px; color: var(--gray-60); white-space: nowrap;
  }
  .upcoming-title { font-size: 15px; font-weight: 500; }
  .upcoming-arrow {
    font-size: 16px; color: var(--red);
    opacity: 0; transition: opacity 0.2s;
  }
  .upcoming-film:hover .upcoming-arrow { opacity: 1; }
  .see-all {
    font-size: 13px; color: var(--red); text-decoration: none;
    font-weight: 500; white-space: nowrap; padding-top: 4px;
    transition: opacity 0.15s;
  }
  .see-all:hover { opacity: 0.7; }

  /* ── SERVICES ── */
  .services {
    padding: 80px 48px;
    border-bottom: 1px solid var(--gray-20);
  }
  .services-header {
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 48px; align-items: end;
    margin-bottom: 56px;
  }
  h2 {
    font-family: var(--display);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 300; line-height: 1.15;
    letter-spacing: -0.01em;
  }
  .services-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 1px; background: var(--gray-20);
    border: 1px solid var(--gray-20);
  }
  .service-card {
    background: var(--white);
    padding: 32px 28px;
    text-decoration: none; color: inherit;
    display: flex; flex-direction: column; gap: 12px;
    transition: background 0.2s;
  }
  .service-card:hover { background: var(--gray-10); }
  .service-number {
    font-size: 11px; color: var(--red); font-weight: 500;
    letter-spacing: 0.08em;
  }
  .service-name {
    font-size: 16px; font-weight: 500; line-height: 1.3;
  }
  .service-desc {
    font-size: 13px; color: var(--gray-60); line-height: 1.6;
    flex: 1;
  }
  .service-link {
    font-size: 12px; color: var(--red); font-weight: 500;
    margin-top: 8px;
  }

  /* ── CTA ── */
  .cta-section {
    padding: 96px 48px;
  }
  .cta-inner {
    display: flex; align-items: center; justify-content: space-between;
    max-width: 900px;
  }
  .cta-inner h2 { margin-bottom: 0; }
  .cta-btn {
    display: inline-block; flex-shrink: 0;
    background: var(--red); color: var(--white);
    padding: 14px 28px; border-radius: 100px;
    font-size: 13px; font-weight: 500; letter-spacing: 0.04em;
    text-decoration: none; transition: opacity 0.2s;
  }
  .cta-btn:hover { opacity: 0.85; }

  @media (max-width: 700px) {
    .hero { padding: 80px 24px 56px; }
    .upcoming { padding: 48px 24px; }
    .upcoming-inner { grid-template-columns: 1fr; gap: 24px; }
    .services { padding: 56px 24px; }
    .services-header { grid-template-columns: 1fr; }
    .services-grid { grid-template-columns: 1fr 1fr; }
    .cta-section { padding: 64px 24px; }
    .cta-inner { flex-direction: column; align-items: flex-start; gap: 24px; }
  }
</style>