      <div class="film-card">
        <div class="film-poster p2"></div>
        <div class="film-badge badge-soon">1. júlí</div>
        <div class="film-title">Skósveinar og skrímsli</div>
        <div class="film-date">1. júlí 2026</div>
      </div>
      <div class="film-card">
        <div class="film-poster p6"></div>
        <div class="film-badge badge-soon">16. júlí</div>
        <div class="film-title">The Odyssey</div>
        <div class="film-date">16. júlí 2026</div>
      </div>
      <div class="film-card">
        <div class="film-poster p7"></div>
        <div class="film-badge badge-soon">13. ágúst</div>
        <div class="film-title">One Night Only</div>
        <div class="film-date">13. ágúst 2026</div>
      </div>
      <div class="film-card">
        <div class="film-poster p3"></div>
        <div class="film-badge badge-soon">13. ágúst</div>
        <div class="film-title">Cliffhanger</div>
        <div class="film-date">13. ágúst 2026</div>
      </div>
      <div class="film-card">
        <div class="film-poster p8"></div>
        <div class="film-badge badge-soon">20. ágúst</div>
        <div class="film-title">Spa Weekend</div>
        <div class="film-date">20. ágúst 2026</div>
      </div>
      <div class="film-card">
        <div class="film-poster p4"></div>
        <div class="film-badge badge-soon">3. september</div>
        <div class="film-title">By Any Means</div>
        <div class="film-date">3. september 2026</div>
      </div>
      <div class="film-card">
        <div class="film-poster p1"></div>
        <div class="film-badge badge-soon">9. september</div>
        <div class="film-title">Onslaught</div>
        <div class="film-date">9. september 2026</div>
      </div>
      <div class="film-card">
        <div class="film-poster p5"></div>
        <div class="film-badge badge-soon">19. nóvember</div>
