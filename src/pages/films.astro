  <section id="tab-archive" class="tab-content film-section" style="display:none">
    <div class="film-list">
      <a href="#" class="film-row">
        <span class="film-row-date">September 2025</span>
        <span class="film-row-title">Him</span>
        <span class="film-row-arrow">→</span>
