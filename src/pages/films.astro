---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Kvikmyndadreifing">

  <section class="page-hero">
    <div class="hero-label">Myndform</div>
    <h1>Kvikmynda<em>dreifing</em></h1>
    <p>Við dreifum erlendum og innlendum kvikmyndum til íslenskra kvikmyndahúsa.</p>
  </section>

  <section class="film-tabs-section fade-in">
    <div class="film-tabs">
      <button class="tab active" data-tab="now">Í bíó núna</button>
      <button class="tab" data-tab="soon">Væntanlegt</button>
      <button class="tab" data-tab="archive">Eldri myndir</button>
    </div>
  </section>

  <div id="tab-now" class="tab-content film-section fade-in">
    <div class="film-grid">
      <div class="film-card">
        <div class="film-poster p3"></div>
        <div class="film-badge badge-now">Í bíó</div>
        <div class="film-title">The Furious</div>
        <div class="film-date">18. júní 2026</div>
      </div>
      <div class="film-card">
        <div class="film-poster p4"></div>
        <div class="film-badge badge-now">Í bíó</div>
        <div class="film-title">Obsession</div>
        <div class="film-date">28. maí 2026</div>
      </div>
      <div class="film-card">
        <div class="film-poster p1"></div>
        <div class="film-badge badge-now">Í bíó</div>
        <div class="film-title">Backrooms</div>
        <div class="film-date">28. maí 2026</div>
      </div>
      <div class="film-card">
        <div class="film-poster p5"></div>
        <div class="film-badge badge-now">Í bíó</div>
        <div class="film-title">Disclosure Day</div>
        <div class="film-date">10. júní 2026</div>
      </div>
    </div>
  </section>

  <section id="tab-soon" class="tab-content film-section" style="display:none">
