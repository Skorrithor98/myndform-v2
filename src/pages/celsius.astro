---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Celsius">

  <section class="page-hero">
    <div class="hero-label">Myndform dreifir</div>
    <h1>Cel<em>sius</em></h1>
    <p>Celsius er einn vinsælasti orkudrykkur sinnar tegundar í Bandaríkjunum og á Norðurlöndunum — 100% náttúrulegur, sykurlaus og fullur af orku.</p>
  </section>

  <section class="intro-section fade-in">
    <div class="intro-text">
      <div class="section-label">Um drykkinn</div>
      <h2>Orkudrykkur<br/>sem þrýtur af<br/>náttúrulegum efnum</h2>
      <p>Það er ekki að ástæðulausu að Celsius sé einn vinsælasti drykkur sinnar tegundar. Margt íþróttafólk velur að svala þorstanum með Celsius þar sem drykkurinn inniheldur 114 mg af koffíni og er algjörlega kolvetnalaus.</p>
      <p>Ásamt því að vera góð uppspretta koffíns inniheldur drykkurinn grænt te, króm, kalk, engifer og ýmis vel valin vítamín. Celsius er einnig 100% vegan.</p>
      <p>Það verður enginn svikinn af Celsius!</p>
    </div>
    <div class="intro-cans">
      <div class="cans-display">
        <div class="can c1"></div>
        <div class="can c2"></div>
        <div class="can c3"></div>
        <div class="can c4"></div>
      </div>
    </div>
  </section>

  <section class="facts-section fade-in">
    <div class="facts-label">
      <div class="section-label">Staðreyndir</div>
    </div>
    <div class="facts-grid">
      <div class="fact">
        <div class="fact-number">114<span>mg</span></div>
        <div class="fact-label">Koffín á dós</div>
      </div>
      <div class="fact">
        <div class="fact-number">4</div>
        <div class="fact-label">Hitaeiningar</div>
      </div>
      <div class="fact">
        <div class="fact-number">0<span>g</span></div>
        <div class="fact-label">Sykur</div>
      </div>
      <div class="fact">
        <div class="fact-number">100<span>%</span></div>
        <div class="fact-label">Vegan</div>
      </div>
    </div>
  </section>

  <section class="flavours-section fade-in">
    <div class="section-label">Bragðtegundir</div>
    <div class="flavours-grid">
      <div class="flavour f1">
        <div class="flavour-name">Peach Vibe</div>
        <div class="flavour-type">Sparkling</div>
      </div>
      <div class="flavour f2">
        <div class="flavour-name">Strawberry Lemonade</div>
        <div class="flavour-type">Sparkling</div>
      </div>
      <div class="flavour f3">
        <div class="flavour-name">Fantasy Vibe</div>
        <div class="flavour-type">Sparkling · Nýtt</div>
      </div>
      <div class="flavour f4">
        <div class="flavour-name">Cosmic Vibe</div>
        <div class="flavour-type">Sparkling</div>
      </div>
    </div>
  </section>

  <section class="cta-section fade-in">
    <div class="cta-inner">
      <h2>Hefur þú áhuga á að<br/>selja Celsius?</h2>
      <a href="mailto:myndform@myndform.is" class="cta-btn">Hafðu samband</a>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    padding: 96px 48px 80px;
    border-bottom: 1px solid var(--gray-20);
    max-width: 800px;
  }
  .hero-label {
    font-size: 11px; font-weight: 500; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--gray-60); margin-bottom: 24px;
    display: flex; align-items: center; gap: 10px;
  }
  .hero-label::before {
    content: ''; width: 24px; height: 1px; background: #f97316;
  }
  h1 {
    font-family: var(--display);
    font-size: clamp(48px, 7vw, 80px);
    font-weight: 300; line-height: 1.05;
    letter-spacing: -0.02em; margin-bottom: 24px;
  }
  h1 em { font-style: italic; color: #f97316; }
  .page-hero p {
    font-size: 16px; color: var(--gray-60); line-height: 1.7;
  }

  /* ── INTRO ── */
  .intro-section {
    padding: 80px 48px;
    border-bottom: 1px solid var(--gray-20);
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 80px; align-items: center;
  }
  .section-label {
    font-size: 11px; font-weight: 500; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--gray-60); margin-bottom: 24px;
    display: flex; align-items: center; gap: 10px;
  }
  .section-label::before {
    content: ''; width: 24px; height: 1px; background: #f97316;
  }
  h2 {
    font-family: var(--display);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 300; line-height: 1.15;
    letter-spacing: -0.01em; margin-bottom: 24px;
  }
  .intro-text p {
    font-size: 14px; color: var(--gray-60);
    line-height: 1.8; margin-bottom: 16px;
  }
  .intro-text p:last-child { margin-bottom: 0; }

  .cans-display {
    display: flex; align-items: flex-end;
    justify-content: center; gap: 8px;
    padding: 32px; background: var(--gray-10);
    border-radius: 8px; height: 280px;
  }
  .can { border-radius: 6px 6px 4px 4px; flex-shrink: 0; width: 56px; }
  .c1 { height: 160px; background: linear-gradient(180deg, #fb923c, #ea580c); }
  .c2 { height: 190px; background: linear-gradient(180deg, #f43f5e, #e11d48); }
  .c3 { height: 210px; background: linear-gradient(180deg, #a78bfa, #7c3aed); }
  .c4 { height: 175px; background: linear-gradient(180deg, #38bdf8, #0284c7); }

  /* ── FACTS ── */
  .facts-section {
    padding: 80px 48px;
    border-bottom: 1px solid var(--gray-20);
    display: grid; grid-template-columns: 1fr 3fr;
    gap: 64px; align-items: center;
  }
  .facts-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 0; border-left: 1px solid var(--gray-20);
  }
  .fact {
    padding: 32px; border-right: 1px solid var(--gray-20);
    text-align: center;
  }
  .fact-number {
    font-family: var(--display);
    font-size: 48px; font-weight: 300; line-height: 1;
    color: var(--black); margin-bottom: 8px;
  }
  .fact-number span { font-size: 28px; }
  .fact-label { font-size: 12px; color: var(--gray-60); font-weight: 500; }

  /* ── FLAVOURS ── */
  .flavours-section {
    padding: 80px 48px;
    border-bottom: 1px solid var(--gray-20);
  }
  .flavours-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    gap: 12px; margin-top: 24px;
  }
  .flavour {
    border-radius: 8px; padding: 32px 24px;
    aspect-ratio: 3/4;
    display: flex; flex-direction: column; justify-content: flex-end;
  }
  .f1 { background: linear-gradient(135deg, #fb923c, #f97316); }
  .f2 { background: linear-gradient(135deg, #f43f5e, #e11d48); }
  .f3 { background: linear-gradient(135deg, #a78bfa, #7c3aed); }
  .f4 { background: linear-gradient(135deg, #38bdf8, #0284c7); }
  .flavour-name {
    font-size: 18px; font-weight: 600; color: var(--white);
    font-family: var(--display); margin-bottom: 4px; line-height: 1.2;
  }
  .flavour-type {
    font-size: 11px; color: rgba(255,255,255,0.7);
    font-weight: 500; letter-spacing: 0.06em; text-transform: uppercase;
  }

  /* ── CTA ── */
  .cta-section { padding: 96px 48px; }
  .cta-inner {
    display: flex; align-items: center;
    justify-content: space-between; gap: 48px;
  }
  .cta-btn {
    display: inline-block; flex-shrink: 0;
    background: #f97316; color: var(--white);
    padding: 14px 28px; border-radius: 100px;
    font-size: 13px; font-weight: 500; letter-spacing: 0.04em;
    text-decoration: none; transition: opacity 0.2s;
  }
  .cta-btn:hover { opacity: 0.85; }

  @media (max-width: 700px) {
    .page-hero { padding: 72px 24px 48px; }
    .intro-section { grid-template-columns: 1fr; padding: 56px 24px; gap: 40px; }
    .facts-section { grid-template-columns: 1fr; padding: 56px 24px; gap: 32px; }
    .facts-grid { grid-template-columns: repeat(2, 1fr); border-left: none; }
    .fact { border: 1px solid var(--gray-20); border-radius: 4px; }
    .flavours-section { padding: 56px 24px; }
    .flavours-grid { grid-template-columns: repeat(2, 1fr); }
    .cta-section { padding: 64px 24px; }
    .cta-inner { flex-direction: column; align-items: flex-start; gap: 24px; }
  }
</style>