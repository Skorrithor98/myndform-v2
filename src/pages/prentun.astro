---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Prentun">

  <section class="page-hero">
    <div class="hero-label">Hönnun & framleiðsla</div>
    <h1>Pren<em>tun</em></h1>
    <p>Við bjóðum upp á fjölbreytta prentþjónustu — frá bílamerkingum og innréttingafilmum til skiltagerðar og stórra prentverkefna.</p>
  </section>

  <section class="services-section fade-in">
    <div class="services-header">
      <div class="section-label">Þjónusta</div>
      <h2>Hvað við<br/>getum gert</h2>
    </div>
    <div class="services-grid">
      <div class="service-card">
        <div class="service-name">Bílamerkingar</div>
        <div class="service-desc">Fagleg bílamerkingar fyrir einstaklinga og fyrirtæki — allt að fullri þekju.</div>
      </div>
      <div class="service-card">
        <div class="service-name">Innréttingafilmur</div>
        <div class="service-desc">Glugga- og veggfilmur fyrir skrifstofur, verslanir og aðrar byggingar.</div>
      </div>
      <div class="service-card">
        <div class="service-name">Skiltagerð</div>
        <div class="service-desc">Úti- og inniskilt, bannerskilt, kynningarskilt og fleira.</div>
      </div>
      <div class="service-card">
        <div class="service-name">Stór prentverkefni</div>
        <div class="service-desc">Veggpóstur, kynningarefni, bæklingar og önnur stór prentverkefni.</div>
      </div>
      <div class="service-card">
        <div class="service-name">Límmiðar</div>
        <div class="service-desc">Allskonar límmiðar — fyrir vörur, kynningarefni og fleira.</div>
      </div>
      <div class="service-card">
        <div class="service-name">Bæklingar & plaköt</div>
        <div class="service-desc">Fagleg hönnun og prentun á bæklingum, plaköttum og kynningarefni.</div>
      </div>
    </div>
  </section>

  <section class="portfolio-section fade-in">
    <div class="section-label">Verkefni</div>
    <div class="grid-row two">
      <div class="grid-item tall bg-dark">
        <div class="grid-label">Bílamerkingar</div>
      </div>
      <div class="grid-item tall bg-mid">
        <div class="grid-label">Skiltagerð</div>
      </div>
    </div>
    <div class="grid-row four">
      <div class="grid-item sq bg-warm">
        <div class="grid-label">Innréttingafilmur</div>
      </div>
      <div class="grid-item sq bg-slate">
        <div class="grid-label">Veggpóstur</div>
      </div>
      <div class="grid-item sq bg-light">
        <div class="grid-label">Bæklingar</div>
      </div>
      <div class="grid-item sq bg-red">
        <div class="grid-label">Kynningarefni</div>
      </div>
    </div>
  </section>

  <section class="cta-section fade-in">
    <div class="cta-inner">
      <h2>Ertu með prentverkefni í huga?</h2>
      <a href="mailto:myndform@myndform.is" class="cta-btn">Hafðu samband</a>
    </div>
  </section>

</Layout>

<style>
  .page-hero {
    padding: 96px 48px 80px;
    border-bottom: 1px solid var(--gray-20);
    max-width: 800px;
  }
  .hero-label {
    font-size: 11px; font-weight: 500; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--gray-60); margin-bottom: 24px;
    display: flex; align-items: center; gap: 10px;
  }
  .hero-label::before {
    content: ''; width: 24px; height: 1px; background: var(--red);
  }
  h1 {
    font-family: var(--display);
    font-size: clamp(48px, 7vw, 80px);
    font-weight: 300; line-height: 1.05;
    letter-spacing: -0.02em; margin-bottom: 24px;
  }
  h1 em { font-style: italic; color: var(--red); }
  .page-hero p {
    font-size: 16px; color: var(--gray-60); line-height: 1.7;
  }

  /* ── SERVICES ── */
  .services-section {
    padding: 80px 48px;
    border-bottom: 1px solid var(--gray-20);
    display: grid; grid-template-columns: 1fr 2fr;
    gap: 64px; align-items: start;
  }
  .section-label {
    font-size: 11px; font-weight: 500; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--gray-60); margin-bottom: 24px;
    display: flex; align-items: center; gap: 10px;
  }
  .section-label::before {
    content: ''; width: 24px; height: 1px; background: var(--red);
  }
  h2 {
    font-family: var(--display);
    font-size: clamp(28px, 4vw, 44px);
    font-weight: 300; line-height: 1.15;
    letter-spacing: -0.01em;
  }
  .services-grid {
    display: grid; grid-template-columns: 1fr 1fr; gap: 32px;
  }
  .service-name {
    font-size: 15px; font-weight: 500; margin-bottom: 8px;
    padding-bottom: 8px; border-bottom: 1px solid var(--gray-20);
  }
  .service-desc { font-size: 13px; color: var(--gray-60); line-height: 1.7; }

  /* ── PORTFOLIO ── */
  .portfolio-section {
    padding: 80px 48px;
    border-bottom: 1px solid var(--gray-20);
  }
  .grid-row { display: grid; gap: 8px; margin-bottom: 8px; }
  .grid-row.two { grid-template-columns: 1fr 1fr; }
  .grid-row.four { grid-template-columns: repeat(4, 1fr); }
  .grid-item {
    border-radius: 4px; position: relative;
    overflow: hidden; cursor: pointer;
  }
  .grid-item.tall { aspect-ratio: 4/3; }
  .grid-item.sq { aspect-ratio: 1/1; }
  .grid-label {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 28px 16px 14px;
    background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 100%);
    font-size: 11px; font-weight: 500; color: #fff;
    letter-spacing: 0.06em; text-transform: uppercase;
    opacity: 0; transition: opacity 0.2s;
  }
  .grid-item:hover .grid-label { opacity: 1; }

  .bg-dark { background: #1a1a1a; }
  .bg-mid { background: #aaaaaa; }
  .bg-warm { background: #c0a898; }
  .bg-red { background: #c01010; }
  .bg-slate { background: #8898aa; }
  .bg-light { background: #d0ccc8; }

  /* ── CTA ── */
  .cta-section { padding: 96px 48px; }
  .cta-inner {
    display: flex; align-items: center;
    justify-content: space-between; gap: 48px;
  }
  .cta-btn {
    display: inline-block; flex-shrink: 0;
    background: var(--red); color: var(--white);
    padding: 14px 28px; border-radius: 100px;
    font-size: 13px; font-weight: 500; letter-spacing: 0.04em;
    text-decoration: none; transition: opacity 0.2s;
  }
  .cta-btn:hover { opacity: 0.85; }

  @media (max-width: 700px) {
    .page-hero { padding: 72px 24px 48px; }
    .services-section { grid-template-columns: 1fr; padding: 56px 24px; gap: 32px; }
    .services-grid { grid-template-columns: 1fr; }
    .portfolio-section { padding: 56px 24px; }
    .grid-row.four { grid-template-columns: repeat(2, 1fr); }
    .cta-section { padding: 64px 24px; }
    .cta-inner { flex-direction: column; align-items: flex-start; gap: 24px; }
  }
</style>